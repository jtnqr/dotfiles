{{ if eq .chezmoi.os "linux" -}}
#!/bin/bash
# --- Linux specific ---
echo "==> Running Linux/WSL basic tools installation..."

# Install ccache if missing based on package manager
if ! command -v ccache >/dev/null; then
    echo "    Installing ccache..."
    if command -v dnf >/dev/null; then
        sudo dnf install -y ccache
    elif command -v apt-get >/dev/null; then
        sudo apt-get update && sudo apt-get install -y ccache
    fi
fi

if [ ! -f "$HOME/.vim/autoload/plug.vim" ]; then
    echo "    Installing vim-plug..."
    curl -fLo "$HOME/.vim/autoload/plug.vim" --create-dirs \
        https://raw.githubusercontent.com/junegunn/vim-plug/master/plug.vim
fi

if [ ! -d "$HOME/.fzf" ]; then
    echo "    Installing fzf..."
    git clone --depth 1 https://github.com/junegunn/fzf.git ~/.fzf
    ~/.fzf/install --bin
fi

if ! command -v zoxide >/dev/null; then
    echo "    Installing zoxide..."
    curl -sSfL https://raw.githubusercontent.com/ajeetdsouza/zoxide/main/install.sh | sh
fi

echo "==> Linux initialization complete."

{{ else if eq .chezmoi.os "windows" -}}
# --- Windows Specific ---
Write-Host "==> Verifying Windows infrastructure applications via scoop..." -ForegroundColor Cyan

$requiredApps = @("zoxide", "fzf", "fd", "uv", "fnm")
foreach ($app in $requiredApps) {
    if (-not (Get-Command $app -ErrorAction SilentlyContinue)) {
        Write-Host "    [!] Missing $app. Installing via scoop..." -ForegroundColor Yellow
        scoop install $app
    } else {
        Write-Host "    [✓] $app is already installed." -ForegroundColor Green
    }
}

Write-Host "==> Windows verification complete." -ForegroundColor Cyan
{{ end -}}
